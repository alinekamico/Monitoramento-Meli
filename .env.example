# ============================================================
# Credenciais Mercado Livre
# ============================================================
# Copie os valores do .env do projeto "Projeto automação Mercado livre".
# Os tokens são compartilhados — o mesmo App ML serve os dois projetos.

ML_APP_ID=
ML_CLIENT_SECRET=

# Gerados no primeiro login (já preenchidos no projeto de automação existente)
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=

# Preenchido automaticamente após o primeiro get_seller_id()
ML_SELLER_ID=

# ============================================================
# Notificação por e-mail (opcional)
# ============================================================
# Conta Gmail que envia o relatório
EMAIL_REMETENTE=seu@gmail.com
# Senha de App do Gmail (não a senha normal)
# Gerar em: myaccount.google.com → Segurança → Senhas de app
EMAIL_SENHA_APP=
# Quem recebe o relatório (pode ser o mesmo e-mail)
EMAIL_DESTINATARIO=seu@gmail.com
